# Copy to .env and adjust. Loaded automatically by Bun.
# Shares the gateway's Postgres — the gateway owns the Prisma migrations;
# this service only runs `bunx prisma generate`.

DATABASE_URL="postgresql://resa:resa@localhost:5432/resa"

# Server — the gateway forwards reservation routes here (RESERVATION_SERVICE_URL).
# Must NOT be exposed publicly: it trusts the X-Manager-Id header set by the gateway.
PORT=3001
